{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oxenClaw",
  "version": "0.1.0-15",
  "identifier": "ai.oxenclaw.desktop",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "oxenClaw",
        "width": 1280,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "fullscreen": false,
        "visible": true,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' tauri: 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' tauri: ws://localhost:* http://localhost:* ws://127.0.0.1:* http://127.0.0.1:*; img-src 'self' data: blob:; font-src 'self' data:",
      "freezePrototype": true
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "oxenClaw"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "oxenClaw native desktop app",
    "longDescription": "Connect to a oxenClaw gateway with native OS keychain token storage, Action Center / freedesktop notifications with action buttons, and a system tray icon.",
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "C1A9D614-EDFF-4828-A2E2-90D446401F94"
      },
      "nsis": {
        "installMode": "currentUser"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libayatana-appindicator3-1",
          "libgtk-3-0"
        ],
        "section": "utils"
      }
    }
  },
  "plugins": {
    "notification": {},
    "store": {},
    "autostart": {},
    "shell": {
      "open": true
    },
    "os": {}
  }
}
